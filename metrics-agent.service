[Unit]
Description=WISE Metrics Agent Service
After=network.target

[Service]
Type=simple
User=wiseagent
Group=wiseagent
WorkingDirectory=/opt/metrics
ExecStart=/opt/metrics/venv/bin/python /opt/metrics/main.py
Restart=always
RestartSec=10
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target